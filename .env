# ============================================================
# Variáveis de ambiente — BilheteAO
# Copie este ficheiro para .env e preencha com os seus valores
# NUNCA envie o ficheiro .env para o GitHub
# ============================================================

# Supabase — obtenha em https://supabase.com > Project Settings > API
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL pública do site (usado no QR Code)
# Local: http://localhost:3000
# Produção: https://bilheteao.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Porta local
PORT=3000
